<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.jth.dotfiles.startup-apps</string>
	<key>LimitLoadToSessionType</key>
	<string>Aqua</string>
	<key>ProcessType</key>
	<string>Background</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-c</string>
		<string>source "$HOME/.dotfileconfig" &amp;&amp; exec /bin/bash "$DOTFILES/scripts/startup-apps.sh"</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
</dict>
</plist>
