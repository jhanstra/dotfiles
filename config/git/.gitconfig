# Fallback for non-github repos
[credential]
  helper = osxkeychain

# Allows cloning with https for github repos
[credential "https://github.com"]
	helper = !gh auth git-credential

[init]
	defaultBranch = main

[pull]
	# Replay local commits on top of fetched commits instead of creating a merge
	rebase = true # true / false / merges / interactive

[fetch]
	# Drop stale remote-tracking branches that were deleted upstream
	prune = true

[rebase]
	# Temporarily stash a dirty working tree before rebasing, then restore it.
	autoStash = true
	# Keep intermediate branch tips updated when rebasing stacked branches
	updateRefs = true

[rerere]
	# If you already fixed a merge conflict and it shows again, auto-fix with that
	enabled = true

[merge]
	# Show base + both sides in conflict markers
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[commit]
	# Show the staged diff in the commit message editor
	verbose = true

[push]
	# Removes need to run `git push -u origin main` after creating a new branch
	autoSetupRemote = true

[submodule]
	# Recurse into submodules by default for commands that support it.
	recurse = true
